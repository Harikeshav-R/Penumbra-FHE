# ---- Rust ----
/target/
runtime/target/
**/*.rs.bk
# Cargo.lock IS committed: the runtime is the deployable app (publish = false), so we want
# reproducible builds. uv.lock (Python) is committed for the same reason.

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual envs / uv
.venv/
venv/
.env

# ---- Penumbra artifacts ----
# NOTE: gitignore does not support inline comments — a trailing `# ...` becomes part of the
# pattern, so these must stand on their own lines to actually match.
*.fhe
# serialized IR / exported models
*.onnx
# exported model artifacts (examples regenerate these) — EXCEPT the small committed ONNX
# fixture the loader's framework-proof test reloads in CI (tests/test_onnx_fixture.py).
!examples/mnist/digit_cnn.onnx
*.key
# crypto key material — never commit
*.ckpt
# downloaded datasets (MNIST, faces, ...)
data/

# ---- Editors / OS ----
.idea/
.vscode/
*.swp
.DS_Store

# ---- Agent / session scaffolding (local only, never tracked) ----
.claude/
# local code-review notes — not project source
CODE_REVIEW_*.md
